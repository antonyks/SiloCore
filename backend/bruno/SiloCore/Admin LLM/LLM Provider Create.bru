meta {
  name: LLM Provider Create
  type: http
  seq: 2
}

post {
  url: {{host}}/api/admin/llm/providers
  body: json
  auth: inherit
}

headers {
  Authorization: {{token}}
}

body:json {
  {
    "name": "Local Ollama",
    "type": "ollama",
    "baseUrl": "http://host.docker.internal:11434",
    "enabled": true,
    "defaultModel": "{{model}}",
    "timeoutMs": 120000,
    "extraHeaders": {},
    "apiKey": null
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
