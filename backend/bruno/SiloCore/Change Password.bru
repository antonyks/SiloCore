meta {
  name: User Change Password
  type: http
  seq: 9
}

post {
  url: {{host}}/api/users/change-password
  body: json
  auth: inherit
}

headers {
  Authorization: {{token}}
}

body:json {
  {
    "oldPassword": "Admin123!",
    "newPassword": "NewPassword123!"
  }
}

settings {
  encodeUrl: true
  timeout: 0
}
